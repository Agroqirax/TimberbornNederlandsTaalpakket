{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Automatische vertaler",
      "type": "shell",
      "windows": {
        "command": ".\\.venv\\Scripts\\activate && python tools/translate.py ${input:srcPath} ${input:destPath} ${input:lang}"
      },
      "command": "source ./.venv/bin/activate && python3 tools/translate.py ${input:srcPath} ${input:destPath} ${input:lang}",
      "icon": {
        "id": "sparkle",
        "color": "terminal.ansiGreen"
      },
      "detail": "Vertaal een csv bestand automatisch"
    },
    {
      "label": "Spellingscontrole",
      "type": "shell",
      "windows": {
        "command": ".\\.venv\\Scripts\\activate && python tools/spell-check.py ${input:srcPath} ${input:lang}"
      },
      "command": "source ./.venv/bin/activate && python3 tools/spell-check.py ${input:srcPath} ${input:lang}",
      "icon": {
        "id": "symbol-text",
        "color": "terminal.ansiYellow"
      },
      "detail": "Controleer de spelling"
    }
  ],
  "inputs": [
    {
      "id": "srcPath",
      "type": "promptString",
      "description": "Bronbestand",
      "default": "C:\\Program Files (x86)\\Steam\\steamapps\\workshop\\content\\1062090\\MOD_NAAM\\localizations\\enUS_Mod.csv"
    },
    {
      "id": "destPath",
      "type": "promptString",
      "description": "Bestemmingsbestand",
      "default": "./Data/Localizations/Plugins/Mod.ID/nlNL_ModID.csv"
    },
